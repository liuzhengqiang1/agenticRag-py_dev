# 阿里云百炼 API 配置（兼容 OpenAI 格式）
# 获取 API Key：https://bailian.console.aliyun.com/
# OPENAI_API_KEY=your_api_key_here
# OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1 阿里云百炼模型地址
# DASHSCOPE_API_KEY=your_api_key_here
# 说明：
# 1. API Key 在阿里云百炼控制台获取（DashScope API-KEY）
# 2. 阿里云百炼使用 DashScope 服务，完全兼容 OpenAI SDK

# 可选配置（互联网搜索）
# TAVILY_API_KEY=your_tavily_api_key_here

# Redis 配置（用于会话历史存储）
# 请根据实际环境修改以下参数
REDIS_HOST=localhost
REDIS_PORT=63791
REDIS_DB=0
REDIS_PASSWORD=redis
REDIS_USERNAME=

# 说明：
# 1. REDIS_HOST: Redis 服务器地址（本地开发用 localhost，生产环境填实际 IP）
# 2. REDIS_PORT: Redis 端口（默认 6379） 可能出现6379被 Windows 保留端口占用了，因为Hyper-V 虚拟机 / WSL2 虚拟网络
# 3. REDIS_DB: Redis 数据库编号（0-15，默认 0）
# 4. REDIS_PASSWORD: Redis 密码（如果没有设置密码，留空即可）
# 5. REDIS_USERNAME: Redis 用户名（Redis 6.0+ ACL 功能，如果没有，留空即可）

# Elasticsearch 配置（用于向量检索 + BM25 检索）
ES_HOST=localhost
ES_PORT=9200
ES_USERNAME=
ES_PASSWORD=
ES_INDEX_NAME=training_docs

# 说明：
# 1. ES_HOST: Elasticsearch 服务器地址（本地开发用 localhost）
# 2. ES_PORT: Elasticsearch 端口（默认 9200）
# 3. ES_USERNAME: ES 用户名（如果启用了 xpack.security，需要填写）
# 4. ES_PASSWORD: ES 密码（如果启用了 xpack.security，需要填写）
# 5. ES_INDEX_NAME: 索引名称（默认 training_docs）
